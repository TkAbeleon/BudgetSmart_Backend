# ==========================================
# Environment Configuration - EXEMPLE
# ==========================================
# Copier ce fichier vers .env et remplir avec vos valeurs
# Copy this file to .env and fill with your values

# Application
APP_NAME=BudgetSmart
APP_VERSION=1.0.0
APP_PORT=8080
APP_PROFILE=dev

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budgetsmart
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_POOL_SIZE=10

# ==========================================
# JWT Configuration
# ==========================================
# Générer une clé secrète : openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==========================================
# N8N Configuration
# ==========================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/chat
N8N_API_KEY=your-n8n-api-key-here
N8N_TIMEOUT=30000

# ==========================================
# Claude API (Anthropic)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=JSON

# ==========================================
# CORS Configuration
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5678
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# ==========================================
# Server Configuration
# ==========================================
SERVER_SERVLET_CONTEXT_PATH=/api
SERVER_COMPRESSION_ENABLED=true
SERVER_COMPRESSION_MIN_RESPONSE_SIZE=1024

# ==========================================
# Flyway Configuration
# ==========================================
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_OUT_OF_ORDER=false

# ==========================================
# Feature Flags
# ==========================================
FEATURE_ALERTS_ENABLED=true
FEATURE_SAVINGS_ENABLED=true
FEATURE_CHAT_ENABLED=true
